<resources>
    <style name="Base.Theme.SmartDarzi" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/error</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>

        <!-- System bars -->
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:statusBarColor">#FFFFFF</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- No ActionBar color -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <!-- Custom button style -->
        <item name="materialButtonStyle">@style/Widget.SmartDarzi.Button</item>

        <!-- Custom card style -->
        <item name="materialCardViewStyle">@style/Widget.SmartDarzi.CardView</item>
    </style>

    <style name="Theme.SmartDarzi" parent="Base.Theme.SmartDarzi" />

    <!-- Splash Theme: Clean white -->
    <style name="Theme.SmartDarzi.Splash" parent="Base.Theme.SmartDarzi">
        <item name="android:windowBackground">@color/white</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:statusBarColor">#FFFFFF</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Dialog Styles -->
    <style name="ThemeOverlay.Material3.MaterialAlertDialog.Centered" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="materialAlertDialogTitleTextStyle">@style/Widget.SmartDarzi.DialogTitle</item>
    </style>

    <style name="Widget.SmartDarzi.DialogTitle" parent="MaterialAlertDialog.Material3.Title.Text">
        <item name="android:textAlignment">center</item>
    </style>

    <style name="Theme.Design.BottomSheetDialog" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.Design.BottomSheet.Modal</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@color/transparent</item>
    </style>

    <!-- Uber-style Black Button -->
    <style name="Widget.SmartDarzi.Button" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/black</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">56dp</item>
    </style>

    <!-- Outlined Button -->
    <style name="Widget.SmartDarzi.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="strokeColor">@color/gray_200</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">56dp</item>
    </style>

    <!-- Text Button -->
    <style name="Widget.SmartDarzi.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <!-- Uber Card Style -->
    <style name="Widget.SmartDarzi.CardView" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/white</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="contentPadding">0dp</item>
    </style>

    <!-- Chip Styles -->
    <style name="Widget.SmartDarzi.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/gray_100</item>
        <item name="android:textColor">@color/black</item>
        <item name="chipCornerRadius">20dp</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Tab indicator pills -->
    <style name="Widget.SmartDarzi.TabLayout" parent="Widget.Material3.TabLayout">
        <item name="tabIndicatorColor">@color/black</item>
        <item name="tabSelectedTextColor">@color/black</item>
        <item name="tabTextColor">@color/gray_400</item>
        <item name="tabRippleColor">@color/ripple</item>
    </style>

    <!-- TextInputLayout Underline Style -->
    <style name="Widget.SmartDarzi.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/black</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxCornerRadiusTopStart">0dp</item>
        <item name="boxCornerRadiusTopEnd">0dp</item>
        <item name="boxCornerRadiusBottomStart">0dp</item>
        <item name="boxCornerRadiusBottomEnd">0dp</item>
        <item name="hintTextColor">@color/black</item>
        <item name="android:textColorHint">@color/gray_500</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.Circular" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>