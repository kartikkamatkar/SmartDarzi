<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/premium_bg"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="40dp"
        android:paddingBottom="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="#0F172A"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/app_name"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="14dp"
                    android:textColor="@color/white"
                    android:textSize="18sp" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="8dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Circular"
                    app:tint="@color/white" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:paddingHorizontal="16dp"
            android:text="@string/home_subtitle_tailor"
            android:textColor="@color/gray_600"
            android:textSize="14sp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardHomeSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:layout_marginHorizontal="16dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/premium_border"
            app:strokeWidth="1dp">

            <EditText
                android:id="@+id/etHomeSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:drawablePadding="10dp"
                android:gravity="center_vertical"
                android:hint="Search Nearest Tailor"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp"
                android:textColor="@color/black"
                android:textColorHint="@color/gray_500"
                android:textSize="14sp"
                app:drawableStartCompat="@drawable/ic_search"
                app:drawableTint="@color/gray_500" />

        </com.google.android.material.card.MaterialCardView>

        <!-- AI Style Suggestion Section -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardHomeAiStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="#E2E8F0">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_main_gradient"
                android:padding="20dp">

                <ImageView
                    android:id="@+id/ivAiMagic"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_flash"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/white" />

                <TextView
                    android:id="@+id/tvAiBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_status_badge"
                    android:backgroundTint="#FFFFFF"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="SMART TAILOR AI"
                    android:textColor="@color/black"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/ivAiMagic"
                    app:layout_constraintTop_toTopOf="@id/ivAiMagic" />

                <TextView
                    android:id="@+id/tvAiCardTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Your Perfect Look is One Scan Away"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@id/tvAiBadge"
                    app:layout_constraintTop_toBottomOf="@id/tvAiBadge" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHomeAiOutfit"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="@color/white"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Analyze My Style"
                    android:textAllCaps="false"
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    app:cornerRadius="12dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvAiCardTitle" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Personalized Suggestions"
                    android:textColor="#B3FFFFFF"
                    android:textSize="11sp"
                    app:layout_constraintBottom_toBottomOf="@id/btnHomeAiOutfit"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/btnHomeAiOutfit" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/bannerViewPager"
            android:layout_width="match_parent"
            android:layout_height="176dp"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="16dp" />

        <LinearLayout
            android:id="@+id/bannerDots"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:orientation="horizontal" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/home_categories_section_title"
                android:textColor="@color/premium_text_primary"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSeeAllCategories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_see_all"
                android:textColor="@color/premium_accent_gold"
                android:textSize="13sp" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:overScrollMode="never"
            android:paddingHorizontal="16dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <include android:id="@+id/catAll" layout="@layout/item_home_category_preview" />
                <include android:id="@+id/catShirt" layout="@layout/item_home_category_preview" />
                <include android:id="@+id/catPants" layout="@layout/item_home_category_preview" />
                <include android:id="@+id/catSuit" layout="@layout/item_home_category_preview" />
                <include android:id="@+id/catKurta" layout="@layout/item_home_category_preview" />
                <include android:id="@+id/catBlouse" layout="@layout/item_home_category_preview" />
                <include android:id="@+id/catLehenga" layout="@layout/item_home_category_preview" />
                <include android:id="@+id/catSaree" layout="@layout/item_home_category_preview" />
                <include android:id="@+id/catWedding" layout="@layout/item_home_category_preview" />
                <include android:id="@+id/catAlterations" layout="@layout/item_home_category_preview" />
            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/home_popular_now"
                android:textColor="@color/premium_text_primary"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvViewAllServices"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_see_all"
                android:textColor="@color/premium_accent_gold"
                android:textSize="13sp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvServices"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            android:paddingHorizontal="10dp"
            android:paddingTop="10dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="80dp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
