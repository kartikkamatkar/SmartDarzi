<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/premium_card"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

    <ImageView
        android:id="@+id/ivBasketItem"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="@drawable/bg_category_icon"
        android:contentDescription="@null"
        android:padding="14dp"
        android:src="@drawable/ic_services"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvBasketItemName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:textColor="@color/premium_text_primary"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/btnRemoveItem"
        app:layout_constraintStart_toEndOf="@id/ivBasketItem"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvBasketItemCategory"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="4dp"
        android:textColor="@color/gray_600"
        android:textSize="12sp"
        app:layout_constraintStart_toEndOf="@id/ivBasketItem"
        app:layout_constraintTop_toBottomOf="@id/tvBasketItemName"
        app:layout_constraintWidth_default="spread"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvBasketItemPrice"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="10dp"
        android:textColor="@color/premium_text_primary"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/ivBasketItem"
        app:layout_constraintTop_toBottomOf="@id/tvBasketItemCategory"
        app:layout_constraintWidth_default="spread"
        app:layout_constraintEnd_toStartOf="@id/qtyRow" />

    <LinearLayout
        android:id="@+id/qtyRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="@id/tvBasketItemPrice"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvBasketItemPrice">

        <TextView
            android:id="@+id/btnMinusQty"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_category_icon"
            android:gravity="center"
            android:text="@string/symbol_minus"
            android:textColor="@color/premium_text_primary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvQty"
            android:layout_width="28dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/premium_text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnPlusQty"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@color/premium_button"
            android:gravity="center"
            android:text="@string/symbol_plus"
            android:textColor="@color/white"
            android:textSize="16sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/btnRemoveItem"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:contentDescription="@null"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:tint="@color/gray_600"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
