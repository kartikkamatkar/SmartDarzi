<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/premium_bg"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingTop="20dp"
    android:paddingBottom="12dp">

    <!-- TITLE -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/ai_outfit_title"
        android:textColor="@color/premium_text_primary"
        android:textSize="26sp"
        android:layout_marginTop="30dp"
        android:textStyle="bold" />

    <!-- SUBTITLE -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/ai_outfit_subtitle"
        android:textColor="@color/gray_600"
        android:textSize="14sp" />

    <!-- BUTTON -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSuggestOutfit"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="16dp"
        android:text="@string/ai_outfit_cta"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:backgroundTint="@color/premium_button"
        app:cornerRadius="16dp"
        app:elevation="3dp" />
    <!-- LIST -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvOutfitSuggestions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="14dp"
        android:paddingBottom="8dp" />

</LinearLayout>
