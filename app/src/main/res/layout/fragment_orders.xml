<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/premium_bg"
    android:fitsSystemWindows="false">

    <TextView
        android:id="@+id/tvOrdersTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:paddingTop="56dp"
        android:paddingHorizontal="16dp"
        android:text="@string/my_orders"
        android:textColor="@color/premium_text_primary"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/orderTabsRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvOrdersTitle">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTabUpcoming"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="@string/tab_upcoming"
            android:textAllCaps="false"
            android:textSize="12sp"
            app:backgroundTint="@color/premium_button"
            app:cornerRadius="18dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTabCompleted"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/tab_completed"
            android:textAllCaps="false"
            android:textColor="@color/gray_600"
            android:textSize="12sp"
            app:backgroundTint="@color/premium_card"
            app:cornerRadius="18dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTabCancelled"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/tab_cancelled"
            android:textAllCaps="false"
            android:textColor="@color/gray_600"
            android:textSize="12sp"
            app:backgroundTint="@color/premium_card"
            app:cornerRadius="18dp" />

    </LinearLayout>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/ordersViewPager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/orderTabsRow" />

</androidx.constraintlayout.widget.ConstraintLayout>

