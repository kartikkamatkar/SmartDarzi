<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:rippleColor="@color/gray_200"
    app:strokeColor="@color/premium_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTailorName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="Shree Ganesh Tailors"
                android:textColor="@color/premium_text_primary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvTailorAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-medium"
                android:text="Near Gandhi Chowk, Yavatmal"
                android:textColor="@color/gray_600"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCallTailor"
                style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="8dp"
                app:icon="@android:drawable/ic_menu_call"
                app:iconTint="@color/premium_accent_gold"
                app:backgroundTint="#F8FAFC" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLocationTailor"
                style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:padding="8dp"
                app:icon="@android:drawable/ic_menu_mylocation"
                app:iconTint="@color/premium_accent_gold"
                app:backgroundTint="#F8FAFC" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
