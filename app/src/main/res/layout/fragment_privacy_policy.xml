<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/premium_bg"
    android:orientation="vertical">

    <View
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/premium_bg" />

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarPrivacy"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/premium_bg"
        app:title="Privacy Policy"
        app:titleCentered="true"
        app:titleTextColor="@color/premium_text_primary"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/premium_text_primary"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="40dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/premium_card"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F5F9">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp"
                    android:lineSpacingExtra="6dp"
                    android:text="Your privacy is important to us. SmartDarzi collects minimal data only for providing tailoring services. We do not sell your personal data to third parties.\n\nData We Collect:\n- Name and Email for account management.\n- Phone number for delivery updates.\n- Body measurements for tailoring services.\n\nSecurity:\nWe use industry-standard encryption to protect your data. Your measurements are only shared with the assigned tailor."
                    android:textColor="@color/premium_text_secondary"
                    android:textSize="15sp" />

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
