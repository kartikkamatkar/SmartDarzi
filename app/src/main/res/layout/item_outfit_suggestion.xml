<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:cardBackgroundColor="@color/premium_card"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <ImageView
            android:id="@+id/ivOutfitImage"
            android:layout_width="match_parent"
            android:layout_height="164dp"
            android:background="@color/gray_100"
            android:contentDescription="@string/design_image_content_description"
            android:padding="20dp"
            android:scaleType="centerInside" />

        <TextView
            android:id="@+id/tvOutfitTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/premium_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvOutfitSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/gray_600"
            android:textSize="13sp" />

    </LinearLayout>

    <View
        android:layout_width="44dp"
        android:layout_height="3dp"
        android:layout_gravity="end|top"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="14dp"
        android:background="@color/premium_accent_gold"
        android:alpha="0.8" />

</com.google.android.material.card.MaterialCardView>

