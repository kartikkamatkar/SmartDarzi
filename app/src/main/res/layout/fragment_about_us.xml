<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/premium_bg"
    android:orientation="vertical">

    <View
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/premium_bg" />

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarAbout"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/premium_bg"
        app:title="About SmartDarzi"
        app:titleCentered="true"
        app:titleTextColor="@color/premium_text_primary"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/premium_text_primary"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="40dp"
            android:gravity="center_horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="@color/premium_button"
                app:cardCornerRadius="60dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="28dp"
                    app:tint="@color/white"
                    android:src="@drawable/ic_logo" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SmartDarzi"
                android:textColor="@color/premium_text_primary"
                android:textSize="28sp"
                android:fontFamily="sans-serif-black"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Premium Tailoring App"
                android:textColor="@color/accent"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="32dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/premium_card"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F5F9">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp"
                    android:lineSpacingExtra="6dp"
                    android:text="SmartDarzi is an innovative platform for personalized tailoring services. Our mission is to combine traditional craftsmanship with modern technology to provide you with the perfect fit from the comfort of your home.\n\nFounded in 2024, SmartDarzi serves thousands of customers across the nation, partnering with skilled master tailors to bring high-end bespoke fashion to everyone."
                    android:textColor="@color/premium_text_secondary"
                    android:textSize="15sp" />

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="© 2026 SmartDarzi Team"
                android:textColor="@color/gray_400"
                android:textSize="12sp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
