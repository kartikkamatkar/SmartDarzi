<resources>
    <style name="Base.Theme.SmartDarzi" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/surface</item>
        <item name="colorOnPrimary">@color/primary</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/primary_dark</item>
        <item name="colorOnBackground">@color/white</item>
        <item name="colorSurface">@color/primary</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorError">@color/error</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.SmartDarzi" parent="Base.Theme.SmartDarzi" />

    <style name="Theme.SmartDarzi.Splash" parent="Base.Theme.SmartDarzi">
        <item name="android:windowBackground">@color/primary_dark</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">@color/transparent</item>
    </style>
</resources>