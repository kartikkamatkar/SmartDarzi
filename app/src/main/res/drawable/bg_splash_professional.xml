<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#FF0E0E0E"
                android:startColor="#FF1E1E1E"
                android:type="linear" />
        </shape>
    </item>

    <item android:gravity="bottom">
        <shape android:shape="rectangle">
            <solid android:color="#19FFFFFF" />
            <corners
                android:topLeftRadius="52dp"
                android:topRightRadius="52dp" />
            <size android:height="280dp" />
        </shape>
    </item>

    <item android:gravity="top|end">
        <shape android:shape="oval">
            <solid android:color="#14E3A11B" />
            <size
                android:width="180dp"
                android:height="180dp" />
        </shape>
    </item>
</layer-list>

